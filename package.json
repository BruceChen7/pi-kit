{
  "name": "pi-kit",
  "version": "0.1.0",
  "description": "A collection of Pi Agent extensions and utilities",
  "keywords": [
    "pi-package"
  ],
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "^0.70.0",
    "@mariozechner/pi-tui": "^0.70.0"
  },
  "pi": {
    "extensions": [
      "./extensions/copyx",
      "./extensions/skill-toggle",
      "./extensions/bash-hook",
      "./extensions/env-guard",
      "./extensions/rtk-rewrite",
      "./extensions/plannotator-auto",
      "./extensions/dirty-git-status",
      "./extensions/codex-plan-limits",
      "./extensions/feature-workflow",
      "./extensions/todo-workflow",
      "./extensions/diffx-review",
      "./extensions/session-path-copy",
      "./extensions/remote-approval",
      "./extensions/agent-end-code-simplifier"
    ]
  },
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "update": "npm update",
    "update:pi-agent": "node scripts/update-pi-coding-agent.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "lint-staged": {
    "*": "biome format --write"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49"
  }
}
