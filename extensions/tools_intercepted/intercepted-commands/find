#!/bin/bash
# Intercept find to suggest fd (faster alternative from rust)

echo "Error: 'find' is disabled. Use 'fd' instead (faster, modern alternative):" >&2
echo "" >&2
echo "  fd PATTERN              # Find files matching pattern" >&2
echo "  fd -e ext PATTERN       # Find files with extension" >&2
echo "  fd -t d PATTERN         # Find directories" >&2
echo "  fd -t f PATTERN         # Find files" >&2
echo "  fd -I PATTERN         # Include ignored files (.gitignore)" >&2
echo "  fd -H PATTERN         # Include hidden files" >&2
echo "  fd -u PATTERN         # Unrestricted (--no-ignore --hidden)" >&2
echo "  fd --no-ignore-vcs    # Only ignore .gitignore, keep .ignore" >&2
echo "" >&2
echo "  Install: brew install fd          # macOS" >&2
echo "           apt install fd            # Ubuntu/Debian" >&2
echo "           pacman -S fd              # Arch Linux" >&2
echo "" >&2
exit 1