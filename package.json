{
  "name": "pi-kit",
  "version": "0.1.0",
  "description": "A collection of Pi Agent extensions and utilities",
  "keywords": [
    "pi-package"
  ],
  "peerDependencies": {
    "@earendil-works/pi-ai": "^0.80.10",
    "@earendil-works/pi-coding-agent": "^0.80.10",
    "@earendil-works/pi-tui": "^0.80.10"
  },
  "pi": {
    "extensions": [
      "./extensions/copyx",
      "./extensions/multi-edit",
      "./extensions/skill-toggle",
      "./extensions/plugin-toggle",
      "./extensions/bash-hook",
      "./extensions/env-guard",
      "./extensions/rtk-rewrite",
      "./extensions/plannotator-auto",
      "./extensions/plan-mode",
      "./extensions/codex-plan-limits",
      "./extensions/feature-workflow",
      "./extensions/kanban-worktree",
      "./extensions/todo-workflow",
      "./extensions/cr-diffview",
      "./extensions/session-path-copy",
      "./extensions/codex-web-search",
      "./extensions/deepseek-search",
      "./extensions/file-watcher",
      "./extensions/review-feedback",
      "./extensions/scheduled-tasks",
      "./extensions/brainstorm-events",
      "./extensions/cache-graph",
      "./extensions/librarian",
      "./extensions/btw",
      "./extensions/opencode-go-provider",
      "./extensions/qmd-search",
      "./extensions/herdr-squad"
    ]
  },
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "update": "npm update",
    "update:pi-agent": "node scripts/update-pi-coding-agent.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "kanban-worktree:ui:build": "vite build --config extensions/kanban-worktree/vite.config.mts",
    "cache-graph:ui:build": "vite build --config extensions/cache-graph/vite.config.mts",
    "pi-webterm:dev": "cd pi-webterm/server && npx tsx watch src/index.ts",
    "pi-webterm:start": "cd pi-webterm/server && npx tsx src/index.ts --cwd ~/work --username 123 --password my654321",
    "pi-webterm:ui:build": "cd pi-webterm/ui && npx vite build",
    "pi-webterm:install": "cd pi-webterm/server && npm install && cd ../ui && npm install",
    "prepack": "npm run kanban-worktree:ui:build && npm run cache-graph:ui:build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*": "biome format --write"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@jackwener/opencli": "^1.8.2",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "svelte": "^5.0.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49",
    "defuddle": "0.14.0",
    "diff": "^8.0.4",
    "glimpseui": "^0.8.1",
    "typebox": "^1.1.38"
  }
}
