{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**",
      "!extensions/kanban-worktree/ui-dist",
      "!extensions/cache-graph/ui-dist",
      "!skills/render-markdown/scripts"
    ]
  },
  "overrides": [
    {
      "includes": ["**/*.svelte"],
      "formatter": {
        "indentWidth": 2
      },
      "javascript": {
        "formatter": {
          "quoteStyle": "double"
        }
      },
      "linter": {
        "rules": {
          "recommended": true,
          "correctness": {
            "noUnusedVariables": "off"
          }
        }
      }
    }
  ],
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
